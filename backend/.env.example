APP_ENV=development
HTTP_ADDR=:8080

DATABASE_URL=postgres://bubbleforge:bubbleforge@localhost:5432/bubbleforge?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Replace before production. API keys will be encrypted with a server-side key.
ENCRYPTION_KEY=change-me-to-a-32-byte-secret-key

# Replace before production. Use a long random value.
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_ISSUER=bubbleforge-api
JWT_AUDIENCE=bubbleforge-app
ACCESS_TOKEN_TTL=15m
